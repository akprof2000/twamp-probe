{
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:443",
  "Probe": {
    "MaxParallel": 1024,
    "MaxPendingResults": 100000
  },
  "Auth": {
    "ApiKey": ""
  },
  "ping": {
    "name": "ping",
    "default": ""
  },
  "twamp": {
    "name": "./twping",
    "default": ""
  },
  "NLog": {
    "autoReload": true,
    "throwConfigExceptions": true,
    "internalLogLevel": "Error",
    "extensions": [
      { "assembly": "NLog.Extensions.Logging" },
      { "assembly": "NLog.Web.AspNetCore" },
      { "assembly": "NLog.Targets.AtomicFile" },
      { "assembly": "NLog.Targets.GZipFile" }
    ],
    "variables": {
      "msg01": "${message} ${onexception:${newline}${exception:maxInnerExceptionLevel=10:format=tostring,data}}",
      "msg02": "${replace-newlines:replacement=\\n\\t:${msg01}}",
      "msg03": "[${date:format=MM.dd HH\\:mm\\:ss.ff} ${uppercase:${level}:padding=-1:fixedLength=true}<${pad:padCharacter=0:padding=2:fixedLength=true:inner=${threadid}}>] (${pad:padding=-60:fixedLength=true:inner=${callsite:className=True:fileName=False:includeSourcePath=False:methodName=True:cleanNamesOfAnonymousDelegates=True}}) ${msg02}"
    },
    "default-wrapper": {
      "type": "AsyncWrapper",
      "overflowAction": "Discard"
    },
    "targets": {
      "own-console": {
        "type": "LimitingWrapper",
        "interval": "00:00:01",
        "messageLimit": 100,
        "target": {
          "type": "ColoredConsole",
          "layout": "${msg03}"
        }
      },
      "async-file": {
        "type": "AsyncWrapper",
        "queueLimit": 10000,
        "overflowAction": "Discard",
        "target": {
          "name": "file",
          "type": "AtomFile",
          "fileName": "${basedir}/log/BackEnd.log",
          "layout": "${msg03}",
          "maxArchiveFiles": 20,
          "archiveAboveSize": 10485760,
          "archiveNumbering": "Rolling",
          "concurrentWrites": "true",
          "keepFileOpen": false
        }
      },
      "gzip": {
        "type": "GZipFile",
        "fileName": "${basedir}/log/BackEnd.gz",
        "layout": "${msg03}",
        "maxArchiveFiles": 50,
        "archiveAboveSize": 10485760,
        "archiveNumbering": "Rolling",
        "keepFileOpen": true,
        "enablearchivefilecompression": true,
        "archiveFileName": "${basedir}/log/BackEnd.{##}.gz"
      }
    },
    "rules": {
      "0": {
        "logger": "Microsoft.*",
        "maxLevel": "Info",
        "final": true
      },
      "1": {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "own-console"
      },
      "2": {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "async-file,gzip"
      }
    }
  }
}
